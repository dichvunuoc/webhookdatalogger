NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/datalogger
QUAWACO_API_KEYS=dev-key-change-me
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://uat-quawaco.iclever.vn
MAX_READINGS_PER_REQUEST=5000

# Realtime (SSE + Redis Pub/Sub cho multi-instance)
# REALTIME_ENABLED=true
# REALTIME_REDIS_URL=redis://localhost:6379
# REALTIME_REDIS_CHANNEL=datalogger:readings:realtime
# REALTIME_HEARTBEAT_MS=15000
# REALTIME_BACKFILL_LIMIT=500

# Tuỳ chọn: sau khi ghi DB thành công, mirror request sang IOC (vd. https://datalogger-webhook.iclever.vn — cùng contract API, key do IOC cấp cho host đích).
# FALLBACK_WEBHOOK_URL=https://datalogger-webhook.iclever.vn
# FALLBACK_API_KEY=   # bắt buộc nếu dùng POST /api/v1/sync/push-all
