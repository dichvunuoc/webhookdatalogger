# Copy trên VPS: cp .env.production.example .env.production && chmod 600 .env.production
# docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# Mật khẩu DB (không commit file .env.production thật)
POSTGRES_PASSWORD=thay-bang-mat-khau-manh

# API key cho nhà máy (có thể nhiều key, phân tách bằng dấu phẩy)
QUAWACO_API_KEYS=key-thay-the
# Danh sách origin được phép gọi API, cách nhau bởi dấu phẩy
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com,https://uat-quawaco.iclever.vn

# API chỉ lắng nghe trong Docker (service name: api, cổng 3000). Không bind ra host.

# Tuỳ chọn
# POSTGRES_USER=postgres
# POSTGRES_DB=datalogger
# MAX_READINGS_PER_REQUEST=5000
# REALTIME_ENABLED=true
# REALTIME_REDIS_URL=redis://redis:6379
# REALTIME_REDIS_CHANNEL=datalogger:readings:realtime
# REALTIME_HEARTBEAT_MS=15000
# REALTIME_BACKFILL_LIMIT=500

# Mirror sang Quawaco IOC (sau khi UAT nhận thành công). Key phải hợp lệ trên host đích.
# FALLBACK_WEBHOOK_URL=https://datalogger-webhook.iclever.vn
# FALLBACK_API_KEY=
