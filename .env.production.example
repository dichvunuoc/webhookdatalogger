# Copy trên VPS: cp .env.production.example .env.production && chmod 600 .env.production
# docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# Mật khẩu DB (không commit file .env.production thật)
POSTGRES_PASSWORD=thay-bang-mat-khau-manh

# API key cho nhà máy (có thể nhiều key, phân tách bằng dấu phẩy)
QUAWACO_API_KEYS=key-thay-the

# API chỉ lắng nghe trong Docker (service name: api, cổng 3000). Không bind ra host.

# Tuỳ chọn
# POSTGRES_USER=postgres
# POSTGRES_DB=datalogger
# MAX_READINGS_PER_REQUEST=5000
